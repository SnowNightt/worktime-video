{
	"compilerOptions": {
		"target": "ES2022",
		"useDefineForClassFields": true,
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"strict": true,
		"skipLibCheck": true,
		"jsx": "preserve",
		"resolveJsonModule": true,
		"isolatedModules": true,
		"esModuleInterop": true,
		"lib": ["ES2022", "ESNext", "DOM", "DOM.Iterable"],
		"types": ["vite/client", "node"],
		"baseUrl": ".",
		"paths": {
			"@/*": ["src/*"],
			"@shared/*": ["../shared/*"]
		}
	},
	"include": [
		"src/**/*.ts",
		"src/**/*.vue",
		"src/**/*.d.ts",
		"vite.config.ts",
		"../shared/**/*.ts"
	]
}
