// See https://go.microsoft.com/fwlink/?LinkId=733558
// for the documentation about the tasks.json format
{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "watch:all",
			"dependsOn": [
				"watch:tsc",
				"watch:esbuild",
				"watch:webview"
			],
			"dependsOrder": "parallel",
			"problemMatcher": [],
			"presentation": {
				"reveal": "never"
			},
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"label": "watch:esbuild",
			"type": "shell",
			"command": "pnpm",
			"args": [
				"run",
				"watch:esbuild"
			],
			"group": "build",
			"isBackground": true,
			"problemMatcher": "$esbuild-watch",
			"presentation": {
				"group": "watch",
				"reveal": "never"
			}
		},
		{
			"label": "watch:tsc",
			"type": "shell",
			"command": "pnpm",
			"args": [
				"run",
				"watch:tsc"
			],
			"group": "build",
			"isBackground": true,
			"problemMatcher": "$tsc-watch",
			"presentation": {
				"group": "watch",
				"reveal": "never"
			}
		},
		{
			"label": "watch:webview",
			"type": "shell",
			"command": "pnpm",
			"args": [
				"run",
				"watch:webview"
			],
			"group": "build",
			"isBackground": true,
			"problemMatcher": {
				"owner": "vite",
				"fileLocation": "absolute",
				"pattern": {
					"regexp": "."
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": ".*vite.*",
					"endsPattern": ".*Local:.*"
				}
			},
			"presentation": {
				"group": "watch",
				"reveal": "never"
			}
		},
		{
			"label": "watch-tests",
			"type": "shell",
			"command": "pnpm",
			"args": [
				"run",
				"watch-tests"
			],
			"group": "build",
			"isBackground": true,
			"problemMatcher": "$tsc-watch",
			"presentation": {
				"reveal": "never",
				"group": "watch"
			}
		},
		{
			"label": "tasks: watch-tests",
			"dependsOn": [
				"watch:all",
				"watch-tests"
			],
			"dependsOrder": "parallel",
			"problemMatcher": []
		}
	]
}
